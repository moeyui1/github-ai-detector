# GitHub personal access token (required for API access)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# OpenAI API key (only needed if using OpenAI provider)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# OpenAI-compatible endpoint (Azure, GitHub Models, etc.)
# OPENAI_BASE_URL=https://your-endpoint.openai.azure.com/openai/v1/

# Log level control: "1" or "true" = INFO, "debug" = DEBUG, empty or unset = disabled
LOG_ENABLED=1
